# ============================================
# Truly Imagined v3 - Environment Variables
# ============================================
# 
# Copy this file to .env.local and fill in your values
# 
# IMPORTANT: Never commit .env.local to version control
# ============================================

# ----------------
# Node Environment
# ----------------
NODE_ENV=development

# ----------------
# Database (PostgreSQL)
# ----------------
# Connection string format: postgresql://username:password@host:port/database
# Local: postgresql://postgres:password@localhost:5432/trulyimagined_v3
# AWS RDS: postgresql://username:password@your-rds-endpoint.rds.amazonaws.com:5432/trulyimagined_v3
DATABASE_URL=postgresql://trimg_admin:ThundercatsBatman88*@trimg-db-v3.cb6wqc8y2yr8.eu-west-1.rds.amazonaws.com:5432/trulyimagined_v3

# ----------------
# Auth0 Configuration (Next.js SDK)
# ----------------
# Get these values from your Auth0 dashboard: https://manage.auth0.com/

# Secret used to encrypt the session cookie (generate with: openssl rand -hex 32)
AUTH0_SECRET=use_a_long_random_value_at_least_32_characters_long

# Base URL of your application
AUTH0_BASE_URL=http://localhost:3000

# Auth0 domain (your tenant)
AUTH0_ISSUER_BASE_URL=https://your-tenant.auth0.com

# Application Client ID
AUTH0_CLIENT_ID=your_client_id_here

# Application Client Secret
AUTH0_CLIENT_SECRET=your_client_secret_here

# API Audience (API Identifier from Auth0 Dashboard > APIs)
AUTH0_AUDIENCE=https://api.trulyimagined.com

# Legacy (for backward compatibility with Lambda middleware)
AUTH0_DOMAIN=your-tenant.auth0.com

# ----------------
# AWS Configuration
# ----------------
# AWS Region for all services
AWS_REGION=eu-west-2

# API Gateway URL (set after deploying SAM template)
# Format: https://xxxxxxxxxx.execute-api.eu-west-2.amazonaws.com/Prod
API_GATEWAY_URL=http://localhost:3001

# AWS Credentials (for local development - use IAM roles in production)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# ----------------
# Frontend (Next.js)
# ----------------
# Public variables (accessible in browser - prefix with NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=Truly Imagined
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----------------
# Optional: Stripe (Phase 2+)
# ----------------
# STRIPE_SECRET_KEY=sk_test_your_key
# STRIPE_PUBLISHABLE_KEY=pk_test_your_key
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ----------------
# Optional: Logging & Monitoring
# ----------------
# LOG_LEVEL=info
# SENTRY_DSN=your_sentry_dsn_here

# ----------------
# MCP Servers (Model Context Protocol)
# ----------------
# For Claude Desktop integration and AI-assisted infrastructure management
# See scripts/mcp-servers/SETUP_GUIDE.md for detailed setup instructions

# AWS MCP Server
# Create IAM user with policy from scripts/mcp-servers/aws-iam-policy.json
# AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AWS_REGION=us-east-1

# Vercel MCP Server
# Generate token at: https://vercel.com/account/tokens
# Get IDs by running: npx vercel link (in apps/web directory)
# VERCEL_TOKEN=vercel_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VERCEL_PROJECT_ID=prj_xxxxxxxxxxxxxxxx
# VERCEL_TEAM_ID=team_xxxxxxxxxxxxxxxx
