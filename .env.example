# ============================================================
# Truly Imagined v3 — Environment Variables Reference
# ============================================================
#
# Copy to apps/web/.env.local for local development.
# Production values are set in Vercel Dashboard → Settings → Environment Variables.
# Sensitive keys (marked [SECRETS MANAGER]) should also be stored in
# AWS Secrets Manager for production access via shared/utils/src/secrets.ts
#
# ⚠️  Never commit .env.local to git — it is in .gitignore
# ⚠️  Rotate any key that has appeared in a chat/log session
# ============================================================


# ============================================================
# AUTH0 — Authentication (Next.js SDK v4)
# ============================================================
# Source: Auth0 Dashboard → Applications → your app → Settings
# Tenant: kilbowieconsulting.uk.auth0.com (dev) / create prod tenant

AUTH0_BASE_URL=http://localhost:3000
# Production: https://trulyimagined.com

AUTH0_ISSUER_BASE_URL=https://your-tenant.auth0.com
# Format: https://{tenant}.auth0.com

AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
# [SECRETS MANAGER] prod/auth0-client-secret → AUTH0_CLIENT_SECRET
# Rotate every 90 days

AUTH0_SECRET=your_32_char_random_session_secret
# Generate: openssl rand -hex 32
# Used to encrypt session cookies — rotate if compromised

AUTH0_AUDIENCE=https://api.trulyimagined.com
# Must match API Identifier in Auth0 Dashboard → APIs

# Legacy variable (used by some internal helpers alongside AUTH0_BASE_URL)
APP_BASE_URL=http://localhost:3000
AUTH0_DOMAIN=your-tenant.auth0.com


# ============================================================
# DATABASE — PostgreSQL on AWS RDS (eu-west-1)
# ============================================================
# Source: AWS Console → RDS → your instance → Connectivity

DATABASE_URL=postgresql://your_db_user:your_db_password@your-rds-endpoint.eu-west-1.rds.amazonaws.com:5432/trulyimagined_v3
# Format: postgresql://username:password@host:5432/database
# SSL is required — enforced via RDS parameter group rds.force_ssl=1
# After RDS upgrade to PostgreSQL v18.1 R1, update with new endpoint/password

DATABASE_SSL=true


# ============================================================
# AWS — S3, Secrets Manager, CloudWatch
# ============================================================
# Source: AWS Console → IAM → your application user → Access keys
# Use least-privilege role; do NOT use root credentials

AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# S3 Media Storage
AWS_S3_BUCKET_NAME=trimg-actor-media
# Bucket exists in eu-west-1 — confirmed


# ============================================================
# STRIPE — Identity Verification (current) + Billing (Phase 2)
# ============================================================
# Source: Stripe Dashboard → Developers → API keys
# Source (webhook): Stripe Dashboard → Developers → Webhooks → your endpoint

STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
# [SECRETS MANAGER] prod/stripe-secret-key → STRIPE_SECRET_KEY
# Use sk_test_... for local development
# Use sk_live_... for production (already configured in Vercel)

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
# Use pk_test_... for local development

STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
# [SECRETS MANAGER] prod/stripe-webhook-secret → STRIPE_WEBHOOK_SECRET
# ⚠️  REQUIRED — webhook signature verification fails without this
# Source: Stripe Dashboard → Webhooks → your endpoint → Signing secret
# Endpoint to register: https://trulyimagined.com/api/webhooks/stripe
# Events to select: identity.verification_session.*


# ============================================================
# ENCRYPTION — AES-256-GCM field-level encryption (GDPR Art. 32)
# ============================================================
# Encrypts: identity_links.credential_data, verifiable_credentials.credential_json

ENCRYPTION_KEY=your_64_char_hex_key
# [SECRETS MANAGER] prod/encryption-key → ENCRYPTION_KEY
# Generate: node scripts/generate-encryption-key.js
# ⚠️  If this key is lost, encrypted records cannot be recovered
# Rotate annually — use scripts/encrypt-existing-records.js to re-encrypt after rotation


# ============================================================
# W3C VERIFIABLE CREDENTIALS — Ed25519 Issuer Keypair
# ============================================================
# Used by: apps/web/src/lib/verifiable-credentials.ts

ISSUER_ED25519_PUBLIC_KEY=z6Mk_your_multibase_public_key
ISSUER_ED25519_PRIVATE_KEY=zrv_your_multibase_private_key
# [SECRETS MANAGER] prod/vc-issuer-key → ISSUER_ED25519_PRIVATE_KEY
# Generate: node scripts/generate-issuer-keys.js
# ⚠️  Public key is embedded in issued credentials and the DID document
#    — changing it invalidates all previously issued credentials


# ============================================================
# CONSENT PROOF — RSA-2048 JWT Signing Keys
# ============================================================
# Used by: apps/web/src/lib/consent-proof.ts

CONSENT_SIGNING_PRIVATE_KEY="base64_encoded_pem_private_key"
# [SECRETS MANAGER] prod/consent-key → CONSENT_SIGNING_PRIVATE_KEY
# Generate: node scripts/generate-consent-signing-keys.js

CONSENT_SIGNING_PUBLIC_KEY="base64_encoded_pem_public_key"
CONSENT_SIGNING_KEY_ID=consent-key-your_timestamp


# ============================================================
# SENTRY — Error Tracking & Performance Monitoring
# ============================================================
# Source: sentry.io → Settings → Projects → your project → Client Keys (DSN)

SENTRY_DSN=https://your_key@o1234567.ingest.sentry.io/your_project_id
NEXT_PUBLIC_SENTRY_DSN=https://your_key@o1234567.ingest.sentry.io/your_project_id
# Both must be set — NEXT_PUBLIC_ is used client-side, non-prefixed for server

SENTRY_AUTH_TOKEN=sntrys_your_sentry_auth_token
# Source: sentry.io → Settings → Auth Tokens → Create new token
# Scopes needed: project:releases, org:read
# Used by CI/CD for source map uploads (GitHub Actions secret: SENTRY_AUTH_TOKEN)

SENTRY_ORG=your-sentry-org-slug
# Source: sentry.io → Settings → General Settings → Organization Slug

SENTRY_PROJECT=trulyimagined-web
# Source: sentry.io → Projects → your project → slug

SENTRY_ENABLED=true
# Set to false to disable Sentry in development if needed


# ============================================================
# RESEND — Transactional Email
# ============================================================
# Source: resend.com → API Keys
# Free tier: 3,000 emails/month, 100/day

RESEND_API_KEY=re_your_resend_api_key
# ⚠️  Rotate immediately if exposed in any chat or log

RESEND_FROM_EMAIL=notifications@trulyimagined.com
# Must be a verified domain in Resend dashboard
# Do NOT use onboarding@resend.dev in production

RESEND_FROM_NAME=Truly Imagined

ADMIN_EMAILS=adam@kilbowieconsulting.com
# Comma-separated for multiple addresses

USE_MOCK_EMAILS=false
# Set to true in dev to log emails to console instead of sending


# ============================================================
# APPLICATION URLS
# ============================================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: https://trulyimagined.com

NEXT_PUBLIC_APP_NAME=Truly Imagined

API_GATEWAY_URL=http://localhost:3001
# Production: https://your-api-id.execute-api.eu-west-1.amazonaws.com/prod
# Set after SAM deployment of infra/api-gateway/template.yaml


# ============================================================
# MCP SERVERS — Claude Desktop integration (local only, not Vercel)
# ============================================================
# See scripts/mcp-servers/SETUP_GUIDE.md

# AWS MCP Server (Desktop connector — separate IAM user)
# AWS_MCP_ACCESS_KEY_ID=your_mcp_access_key
# AWS_MCP_SECRET_ACCESS_KEY=your_mcp_secret_key
# AWS_MCP_REGION=eu-west-1
