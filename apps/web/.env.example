# ============================================
# Next.js Frontend - Environment Variables
# ============================================
# 
# Copy this file to .env.local
# ============================================

# ----------------
# Auth0 (NextAuth.js)
# ----------------
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id_here
AUTH0_CLIENT_SECRET=your_client_secret_here
AUTH0_ISSUER_BASE_URL=https://your-tenant.auth0.com
AUTH0_SECRET=use_a_long_random_value_at_least_32_characters
AUTH0_BASE_URL=http://localhost:3000
AUTH0_AUDIENCE=https://api.trulyimagined.com
# Auth0 custom claim namespace for roles (configured in Auth0 Actions/Rules)
AUTH0_ROLES_CLAIM_NAMESPACE=https://trulyimagined.com/roles

# ----------------
# API Configuration
# ----------------
# Backend API URL (API Gateway or local SAM)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ----------------
# HDICR Adapter Cutover (Phased Migration)
# ----------------
# Modes: local | remote
# local: use in-repo adapter implementations (dev/test only)
# remote: call HDICR service APIs (required for production)
HDICR_ADAPTER_MODE=remote
# Optional per-domain overrides (only set if intentionally different from global)
# HDICR_IDENTITY_ADAPTER_MODE=remote
# HDICR_CREDENTIALS_ADAPTER_MODE=remote
# Base URL for HDICR remote adapter routing
HDICR_REMOTE_BASE_URL=http://localhost:4001
# Auth0 M2M credentials for TI -> HDICR service-to-service calls
HDICR_CLIENT_ID=your_hdicr_m2m_client_id
HDICR_CLIENT_SECRET=your_hdicr_m2m_client_secret

# ----------------
# Application Settings
# ----------------
NEXT_PUBLIC_APP_NAME=Truly Imagined
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ----------------
# Database (PostgreSQL)
# ----------------
DATABASE_HOST=your-rds-endpoint.region.rds.amazonaws.com
DATABASE_NAME=trulyimagined
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_PORT=5432
DATABASE_SSL=true

# ----------------
# AWS S3 (Media Storage)
# ----------------
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_S3_BUCKET_NAME=trimg-actor-media

# Development: Set to 'true' to use local file system instead of S3
USE_MOCK_S3=true

# ----------------
# Stripe Identity (Step 7 & 8: Identity Verification)
# ----------------
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
# Webhook signing secret for production (from Stripe Dashboard > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ----------------
# KYC Providers (Optional - Legacy)
# ----------------
# Onfido (Optional - if using Onfido instead of Stripe)
ONFIDO_API_TOKEN=test_your_onfido_api_token_here
# Yoti (Optional - if using Yoti instead of Stripe)
YOTI_CLIENT_SDK_ID=your_yoti_sdk_id_here

# ----------------
# Step 10: Consent Proof API (JWT Signing)
# ----------------
# Generate keypair with: node scripts/generate-consent-signing-keys.js
# IMPORTANT: Keep private key secure! Never commit to Git.
# Production: Store in AWS Secrets Manager or similar.
CONSENT_SIGNING_PRIVATE_KEY=LS0tLS1CRUdJTi...
CONSENT_SIGNING_PUBLIC_KEY=LS0tLS1CRUdJTi...
CONSENT_SIGNING_KEY_ID=consent-key-1234567890

# ----------------
# Step 11: Database Field Encryption (AES-256)
# ----------------
# Generate key with: node scripts/generate-encryption-key.js
# Encrypts sensitive JSONB fields: identity_links.credential_data, verifiable_credentials.credential_json
# CRITICAL: Keep this key secure! Loss of key = loss of encrypted data.
# Production: Store in AWS Secrets Manager (required for GDPR Article 32 compliance)
ENCRYPTION_KEY=your_64_character_hex_key_here
